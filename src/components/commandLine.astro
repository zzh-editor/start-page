---
const username = "zzh.editor";
---

<section data-squircle data-squircle-radius="10">
  <div id="prompt">
    <span id="prompt-engine" role="button" tabindex="0" aria-haspopup="listbox">Google</span><span class="prompt-colon">:</span>
  </div>
  <input id="terminal-input" type="text" autocomplete="off" spellcheck="false" placeholder="" />
</section>
<div id="engine-menu" class="engine-menu" role="listbox" hidden></div>
<div id="wf-suggest" class="wf-suggest" role="listbox" hidden></div>

<style>
  section {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 16px;
    padding: 10px 16px;
    border-radius: var(--radius);
    background: var(--surface-translucent);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border: 1px solid var(--border);
    box-shadow: var(--shadow);
    width: 100%;
    transition:
      border-color var(--transition),
      box-shadow var(--transition);
  }

  section:focus-within {
    border-color: var(--accent);
    box-shadow:
      var(--shadow),
      0 0 0 3px color-mix(in srgb, var(--accent) 25%, transparent);
  }

  #prompt {
    font-family: var(--mono);
    font-size: 18px;
    color: var(--muted);
    white-space: nowrap;
    position: relative;
    display: flex;
    align-items: center;
    gap: 0;
    flex-shrink: 0;
  }

  #prompt-engine {
    cursor: pointer;
    user-select: none;
    padding: 2px 6px;
    border-radius: 4px;
    transition: all var(--transition);
  }

  #prompt-engine:hover {
    color: var(--text);
    background: color-mix(in srgb, var(--accent) 12%, transparent);
  }

  .engine-menu {
    position: fixed;
    min-width: 160px;
    background: var(--surface);
    border: 1px solid var(--border);
    box-shadow: var(--shadow);
    z-index: 100;
    display: flex;
    flex-direction: column;
    padding: 4px 0;
  }

  .engine-menu[hidden] {
    display: none;
  }

  .engine-item {
    background: transparent;
    border: none;
    color: var(--text);
    padding: 6px 14px;
    font-size: 13px;
    text-align: left;
    cursor: pointer;
    font-family: inherit;
    transition: all var(--transition);
  }

  .engine-item:hover {
    background: color-mix(in srgb, var(--accent) 12%, transparent);
    transform: translateX(2px);
  }

  .engine-item.active {
    color: var(--accent);
    font-weight: 600;
  }

  .wf-suggest {
    position: fixed;
    min-width: 220px;
    background: var(--surface);
    border: 1px solid var(--border);
    box-shadow: var(--shadow);
    z-index: 99;
    display: flex;
    flex-direction: column;
    padding: 4px 0;
  }

  .wf-suggest[hidden] {
    display: none;
  }

  .wf-suggest-item {
    background: transparent;
    border: none;
    color: var(--text);
    padding: 6px 14px;
    font-size: 13px;
    text-align: left;
    cursor: pointer;
    font-family: inherit;
    transition: all var(--transition);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }

  .wf-suggest-item:hover {
    background: color-mix(in srgb, var(--accent) 12%, transparent);
    transform: translateX(2px);
  }

  .wf-suggest-item.active {
    background: color-mix(in srgb, var(--accent) 18%, transparent);
    color: var(--accent);
    font-weight: 600;
  }

  .wf-suggest-name {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    flex: 1;
    min-width: 0;
  }

  .wf-suggest-count {
    font-size: 11px;
    color: var(--muted);
    flex-shrink: 0;
  }

  .wf-suggest-hint {
    padding: 8px 14px;
    font-size: 11px;
    color: var(--muted);
    text-align: center;
  }

  #browser-info {
    font-weight: 500;
    color: var(--accent);
  }

  #terminal-input {
    background: none;
    border: none;
    font-family: var(--mono);
    font-size: 18px;
    color: var(--text);
    flex: 1;
    min-width: 0;
  }

  #terminal-input:focus {
    outline: none;
  }

  #terminal-input::placeholder {
    color: var(--muted);
  }

  @media (max-width: 1040px) {
    section {
      position: fixed;
      left: 0.75rem;
      right: 0.75rem;
      bottom: max(0.75rem, env(safe-area-inset-bottom));
      width: auto;
      max-width: none;
      flex-direction: row;
      align-items: center;
      gap: 10px;
      padding: 10px 14px;
      z-index: 50;
    }
    #prompt,
    #terminal-input {
      font-size: 15px;
    }
    #terminal-input {
      width: 100%;
    }
  }

  :global(.bookmark-match) {
    opacity: 1 !important;
    transition: all 0.2s ease !important;
  }

  :global(.bookmark-nomatch) {
    opacity: 0.35 !important;
    filter: grayscale(70%) !important;
    transform: scale(0.98) !important;
    transition: all 0.3s ease !important;
  }

  :global(.bookmark-nomatch-parent) {
    text-decoration: line-through !important;
    text-decoration-color: var(--muted) !important;
  }

  :global(.bookmark-list a:hover) {
    background: var(--hover) !important;
    opacity: 1 !important;
    filter: none !important;
    transform: translateX(2px) !important;
  }
</style>

<script>
  import { addBookmark, addCategory, getState, subscribe } from "../lib/store";
  import { showToast, openUrls } from "../lib/helpers";
  import { typePlaceholder, stopTyping, PLACEHOLDER_EXAMPLES } from "../lib/command/typewriter";
  import { highlightMatches, resetStyles, findBookmarkMatch, refreshElements } from "../lib/command/bookmark-match";
  import { navigate, runCategory } from "../lib/command/navigate";
  import { updateSearchEnginePrompt, renderEngineMenu, positionEngineMenu, positionWfSuggest, repositionAllMenus } from "../lib/command/engine-menu";

  function initializeTerminal() {
    const input = document.getElementById("terminal-input") as HTMLInputElement | null;
    if (!input) return;

    let elements: NodeListOf<HTMLAnchorElement> = refreshElements();
    const history: string[] = [];
    let historyIndex = 0;

    updateSearchEnginePrompt();
    typePlaceholder(input, PLACEHOLDER_EXAMPLES);
    resetStyles(elements);

    const host = document.getElementById("bookmark-host");
    if (host) {
      const observer = new MutationObserver(() => {
        const previousValue = input.value;
        elements = refreshElements();
        if (previousValue) highlightMatches(previousValue.toLowerCase(), elements);
      });
      observer.observe(host, { childList: true, subtree: true });
    }

    input.addEventListener("focus", () => { stopTyping(input); });

    input.addEventListener("blur", () => {
      if (input.value === "") {
        resetStyles(elements);
        if (!(window as any).__typingTimer) typePlaceholder(input, PLACEHOLDER_EXAMPLES);
      }
    });

    input.addEventListener("input", () => {
      highlightMatches(input.value.toLowerCase(), elements);
      const v = input.value;
      const wfPrefix = v.match(/^(wf|workflow)\s*(.*)$/i);
      if (wfPrefix) {
        renderWfSuggestions(wfPrefix[2]);
      } else {
        const suggest = document.getElementById("wf-suggest")!;
        if (!suggest.hidden) suggest.hidden = true;
      }
    });

    input.addEventListener("keydown", (event) => {
      const suggest = document.getElementById("wf-suggest")!;

      if (event.key === "Escape") {
        event.stopPropagation();
        if (!suggest.hidden) suggest.hidden = true;
        if (input.value !== "") {
          input.value = "";
          resetStyles(elements);
        }
        event.preventDefault();
        return;
      }

      if (event.key === "ArrowUp") {
        if (!suggest.hidden && wfFiltered.length > 0) {
          event.preventDefault();
          updateWfSuggestionHighlight((wfSuggestionIndex - 1 + wfFiltered.length) % wfFiltered.length);
          return;
        }
        if (historyIndex > 0) {
          historyIndex--;
          input.value = history[historyIndex];
          event.preventDefault();
        }
        return;
      }

      if (event.key === "ArrowDown") {
        if (!suggest.hidden && wfFiltered.length > 0) {
          event.preventDefault();
          updateWfSuggestionHighlight((wfSuggestionIndex + 1) % wfFiltered.length);
          return;
        }
        if (historyIndex < history.length - 1) {
          historyIndex++;
          input.value = history[historyIndex];
        } else {
          historyIndex = history.length;
          input.value = "";
        }
        event.preventDefault();
        return;
      }

      if (event.key === "Enter") {
        if (!suggest.hidden) suggest.hidden = true;

        const value = input.value.trim();
        if (!value) return;

        history.push(value);
        historyIndex = history.length;

        const addMatch = value.match(/^add(?:\s+(\S+))?(?:\s+(.+?)(?:\s+(.+))?)?$/i);
        if (addMatch) {
          const url = addMatch[1];
          const title = addMatch[2]?.trim();
          const catName = addMatch[3]?.trim();
          const state = (window as any).__startpageStore?.();
          if (!state) { showToast("数据未就绪", "error"); return; }
          let catId = "";
          if (catName) {
            const existing = state.categories.find((c: any) => c.name.toLowerCase() === catName.toLowerCase());
            catId = existing ? existing.id : addCategory(catName).id;
          }
          addBookmark({ href: url, title, categoryId: catId });
          showToast(`已添加${title ? `「${title}」` : ""}${catName ? ` → ${catName}` : ""}`, "info");
          input.value = "";
          resetStyles(elements);
          return;
        }

        const runMatch = value.match(/^run\s+(.+)$/i);
        if (runMatch) {
          runCategory(runMatch[1]);
          input.value = "";
          resetStyles(elements);
          return;
        }

        const wfMatch = value.match(/^(?:wf|workflow)[\s+]+?(.+)$/i) || value.match(/^(?:wf|workflow)(.+)$/i);
        if (wfMatch) {
          const needle = wfMatch[1].trim().toLowerCase();
          const state = (window as any).__startpageStore?.();
          if (state) {
            const wf = state.workflows.find((w: any) => w.name.toLowerCase().includes(needle));
            if (wf) {
              const bmUrls = state.bookmarks
                .filter((b: any) => wf.bookmarkIds?.includes(b.id))
                .map((b: any) => b.href);
              const allUrls: string[] = (wf.urls?.length ? wf.urls : bmUrls);
              if (allUrls.length > 0) {
                openUrls(allUrls);
                showToast(`已打开 ${allUrls.length} 个标签页（${wf.name}）`, "info");
              } else {
                showToast(`工作流「${wf.name}」中没有链接`, "error");
              }
            } else {
              showToast(`未找到工作流「${needle}」`, "error");
            }
          }
          input.value = "";
          resetStyles(elements);
          return;
        }

        const match = findBookmarkMatch(value.toLowerCase(), elements);
        if (match) {
          window.open(match.href, "_blank", "noopener,noreferrer");
          input.value = "";
          resetStyles(elements);
        } else {
          navigate(value);
          input.value = "";
          resetStyles(elements);
        }
      }
    });

    // ---------- Engine menu ----------
    const promptEngine = document.getElementById("prompt-engine")!;
    promptEngine.addEventListener("click", (e) => {
      e.stopPropagation();
      const menu = document.getElementById("engine-menu")!;
      if (menu.hidden) {
        renderEngineMenu();
        positionEngineMenu();
        menu.hidden = false;
      } else {
        menu.hidden = true;
      }
    });
    promptEngine.addEventListener("keydown", (e) => {
      if (e.key === "Enter" || e.key === " ") {
        e.preventDefault();
        promptEngine.click();
      }
    });

    document.addEventListener("click", () => {
      const menu = document.getElementById("engine-menu")!;
      if (!menu.hidden) menu.hidden = true;
      const suggest = document.getElementById("wf-suggest")!;
      if (!suggest.hidden) suggest.hidden = true;
    });

    window.addEventListener("scroll", repositionAllMenus, { passive: true });
    window.addEventListener("resize", repositionAllMenus);

    subscribe(() => {
      updateSearchEnginePrompt();
      const menu = document.getElementById("engine-menu")!;
      if (!menu.hidden) {
        renderEngineMenu();
        positionEngineMenu();
      }
    });

    // ---------- Workflow suggestions ----------
    let wfSuggestionIndex = -1;
    let wfFiltered: any[] = [];

    function renderWfSuggestions(prefix: string): void {
      const suggest = document.getElementById("wf-suggest") as HTMLDivElement;
      if (!suggest) return;
      const state = (window as any).__startpageStore?.();
      if (!state) { suggest.hidden = true; return; }
      if (state.workflows.length === 0) {
        suggest.hidden = true;
        wfSuggestionIndex = -1;
        wfFiltered = [];
        return;
      }
      wfFiltered = state.workflows;
      wfSuggestionIndex = 0;
      suggest.innerHTML = wfFiltered.map((w: any, i: number) => {
        const count = (w.urls?.length ?? 0) || state.bookmarks.filter((b: any) => w.bookmarkIds.includes(b.id)).length;
        return `<button type="button" class="wf-suggest-item ${i === 0 ? "active" : ""}" data-wf-id="${w.id}"><span class="wf-suggest-name">${w.name}</span><span class="wf-suggest-count">${count} 项</span></button>`;
      }).join("");
      const inputRect = input.getBoundingClientRect();
      suggest.style.left = inputRect.left + "px";
      suggest.style.top = (inputRect.bottom + 6) + "px";
      suggest.style.minWidth = Math.max(160, inputRect.width) + "px";
      suggest.hidden = false;

      suggest.querySelectorAll<HTMLButtonElement>(".wf-suggest-item").forEach((btn, idx) => {
        btn.addEventListener("click", () => { insertWfSuggestion(idx); });
        btn.addEventListener("mouseenter", () => { updateWfSuggestionHighlight(idx); });
      });
    }

    function updateWfSuggestionHighlight(index: number): void {
      wfSuggestionIndex = index;
      document.querySelectorAll<HTMLButtonElement>(".wf-suggest-item").forEach((item, i) => item.classList.toggle("active", i === index));
    }

    function insertWfSuggestion(index: number): void {
      const wf = wfFiltered[index];
      if (!wf) return;
      input.value = "wf " + wf.name;
      document.getElementById("wf-suggest")!.hidden = true;
      input.focus();
    }

    window.addEventListener("tabs:change", () => {
      wfSuggestionIndex = -1;
      wfFiltered = [];
      const suggest = document.getElementById("wf-suggest")!;
      if (!suggest.hidden) suggest.hidden = true;
    });
  }

  document.addEventListener("DOMContentLoaded", initializeTerminal);
</script>
