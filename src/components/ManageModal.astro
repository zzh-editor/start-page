<script>
  import { getState, subscribe } from "../lib/store";
  import { applyTheme } from "../lib/themes";
  import { showToast, saveFocus, restoreFocus } from "../lib/helpers";

  import { setSharedFns, panelState, type SubKey } from "../lib/manage/shared";
  import { renderTheme } from "../lib/manage/theme-panel";
  import { renderBmGrid, updateSelectionInfo, renderSortMenu, initBookmarksPanel } from "../lib/manage/bookmarks-panel";
  import { renderCatList, initCategoriesPanel } from "../lib/manage/categories-panel";
  import { renderSearch, initSearchPanel } from "../lib/manage/search-panel";
  import { renderWorkflows, initWorkflowsPanel } from "../lib/manage/workflows-panel";
  import { initSyncPanel } from "../lib/manage/sync-panel";

  // ---------- Modal open/close ----------
  const modal = document.getElementById("manage-modal")!;
  const subtabsEl = document.getElementById("subtabs")!;
  let activeSub: SubKey = "theme";

  function openModal(): void {
    saveFocus();
    modal.hidden = false;
    switchSub(activeSub);
    document.body.style.overflow = "hidden";
  }

  let closeCleanup: (() => void) | null = null;

  function closeModal(): void {
    modal.hidden = true;
    document.body.style.overflow = "";
    panelState.selectedIds.clear();
    panelState.editingCatId = null;
    panelState.editingBmId = null;
    panelState.editingWfId = null;
    closeCleanup?.();
    window.dispatchEvent(new CustomEvent("manage:close"));
    restoreFocus();
  }

  window.addEventListener("manage:open", openModal);
  modal.querySelectorAll<HTMLElement>("[data-close]").forEach((el) =>
    el.addEventListener("click", closeModal),
  );
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && !modal.hidden) {
      e.preventDefault();
      closeModal();
    }
  });

  // ---------- Confirm dialog ----------
  const mmConfirm = document.getElementById("mm-confirm")!;
  document.body.appendChild(mmConfirm);
  const mmConfirmTitle = document.getElementById("mm-confirm-title")!;
  const mmConfirmText = document.getElementById("mm-confirm-text")!;
  const mmConfirmOk = document.getElementById("mm-confirm-ok") as HTMLButtonElement;
  let mmConfirmCallback: (() => void) | null = null;

  function openModalConfirm(title: string, message: string, onConfirm: () => void): void {
    mmConfirmTitle.textContent = title;
    mmConfirmText.textContent = message;
    mmConfirmCallback = onConfirm;
    saveFocus();
    requestAnimationFrame(() => { mmConfirm.hidden = false; });
  }

  function closeModalConfirm(): void {
    mmConfirm.hidden = true;
    mmConfirmCallback = null;
    restoreFocus();
  }

  mmConfirm.querySelectorAll<HTMLElement>("[data-mm-confirm-close]").forEach((el) =>
    el.addEventListener("click", closeModalConfirm),
  );
  mmConfirmOk.addEventListener("click", () => {
    if (mmConfirmCallback) mmConfirmCallback();
    closeModalConfirm();
  });
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && !mmConfirm.hidden) closeModalConfirm();
  });

  // ---------- Shared functions injection ----------
  setSharedFns({
    confirm: openModalConfirm,
    toast: showToast,
    saveFocus,
    restoreFocus,
    switchSub: (sub) => switchSub(sub),
  });

  // ---------- Sub-tab switching ----------
  subtabsEl.querySelectorAll<HTMLButtonElement>(".subtab").forEach((btn) => {
    btn.addEventListener("click", () => {
      const sub = btn.dataset.sub as SubKey;
      if (sub) switchSub(sub);
    });
  });

  subtabsEl.addEventListener("keydown", (e) => {
    const btns = Array.from(subtabsEl.querySelectorAll<HTMLButtonElement>(".subtab"));
    const idx = btns.findIndex((b) => b.classList.contains("active"));
    if (idx === -1) return;
    if (e.key === "ArrowRight") {
      e.preventDefault();
      btns[(idx + 1) % btns.length].click();
    } else if (e.key === "ArrowLeft") {
      e.preventDefault();
      btns[(idx - 1 + btns.length) % btns.length].click();
    }
  });

  function switchSub(sub: SubKey): void {
    activeSub = sub;
    subtabsEl.querySelectorAll<HTMLButtonElement>(".subtab").forEach((b) => {
      b.classList.toggle("active", b.dataset.sub === sub);
    });
    modal.querySelectorAll<HTMLElement>(".subpanel").forEach((p) => {
      p.hidden = p.dataset.subpanel !== sub;
    });
    if (sub === "theme") renderTheme(getState());
    if (sub === "bookmarks") {
      renderBmGrid(getState());
      panelState.selectedIds.clear();
      updateSelectionInfo();
      renderSortMenu(getState());
    }
    if (sub === "categories") {
      panelState.editingCatId = null;
      renderCatList(getState());
    }
    if (sub === "search") renderSearch(getState());
    if (sub === "workflows") renderWorkflows(getState());
    if (sub === "sync") {
      closeCleanup = initSyncPanel();
    }
  }

  // ---------- Init panels ----------
  initBookmarksPanel();
  initCategoriesPanel();
  initSearchPanel();
  initWorkflowsPanel();

  // ---------- Store subscription ----------
  subscribe((state) => {
    if (!modal.hidden) {
      if (activeSub === "theme") renderTheme(state);
      if (activeSub === "bookmarks") {
        renderBmGrid(state);
        updateSelectionInfo();
        renderSortMenu(state);
      }
      if (activeSub === "categories") renderCatList(state);
      if (activeSub === "workflows") renderWorkflows(state);
      if (activeSub === "search") renderSearch(state);
    }
    const prevMode = document.documentElement.dataset.mode;
    const prevStyle = document.documentElement.dataset.style;
    if (state.themeMode !== prevMode || state.themeStyle !== prevStyle) {
      applyTheme(state.themeMode, state.themeStyle);
    }
  });

  renderTheme(getState());
</script>
