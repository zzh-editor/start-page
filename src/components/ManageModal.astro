---
// 设置面板：4 sub-tab（主题 / 书签 / 分组 / 快捷键）
// 通过 window 全局事件 manage:open / manage:close 触发
---

<div id="manage-modal" class="modal" hidden>
  <div class="modal-backdrop" data-close></div>
   <div class="panel" data-squircle data-squircle-radius="16" role="dialog" aria-modal="true" aria-labelledby="modal-title">
    <header class="panel-header">
      <h2 id="modal-title">设置</h2>
      <button type="button" class="icon-btn" aria-label="关闭" data-close>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    </header>

    <nav class="subtabs" id="subtabs" aria-label="设置分组">
      <button type="button" class="subtab active" data-sub="theme" data-squircle data-squircle-radius="999">主题</button>
      <button type="button" class="subtab" data-sub="bookmarks" data-squircle data-squircle-radius="999">书签</button>
      <button type="button" class="subtab" data-sub="categories" data-squircle data-squircle-radius="999">分组</button>
      <button type="button" class="subtab" data-sub="workflows" data-squircle data-squircle-radius="999">工作流</button>
      <button type="button" class="subtab" data-sub="search" data-squircle data-squircle-radius="999">搜索引擎</button>
      <button type="button" class="subtab" data-sub="shortcuts" data-squircle data-squircle-radius="999">快捷键</button>
      <button type="button" class="subtab" data-sub="sync" data-squircle data-squircle-radius="999">同步</button>
    </nav>

    <div class="panel-body">
      <!-- ============== 主题 ============== -->
      <section class="subpanel" data-subpanel="theme" hidden>
        <div class="theme-cards" id="theme-cards"></div>
        <div class="theme-mode" id="theme-mode">
          <span class="theme-mode-label">模式</span>
          <div class="theme-mode-group" data-squircle data-squircle-radius="999">
            <button type="button" data-mode="light" data-squircle data-squircle-radius="999">浅色</button>
            <button type="button" data-mode="dark" data-squircle data-squircle-radius="999">深色</button>
          </div>
        </div>
      </section>

      <!-- ============== 书签 ============== -->
      <section class="subpanel" data-subpanel="bookmarks" hidden>
          <div class="bm-toolbar">
          <div class="bm-toolbar-left">
            <button type="button" class="btn primary" id="bm-add">+ 添加</button>
            <button type="button" class="btn" id="bm-batch">批量</button>
          </div>
          <div class="bm-toolbar-right">
            <span class="bm-selection-info" id="bm-selection-info"></span>
            <button type="button" class="btn" id="bm-select-all">全选</button>
            <div class="bm-sort-wrap">
              <button type="button" class="btn" id="bm-sort">排序 ▾</button>
              <div class="bm-sort-menu" id="bm-sort-menu" hidden>
                <button type="button" class="bm-sort-item" data-sort="alpha">首字母</button>
                <button type="button" class="bm-sort-item" data-sort="added">添加时间</button>
              </div>
            </div>
          </div>
        </div>

        <div class="bm-form" id="bm-form" hidden data-squircle data-squircle-radius="16">
          <label for="bm-form-title" class="sr-only">标题</label>
          <input type="text" id="bm-form-title" placeholder="标题（可选）" />
          <label for="bm-form-url" class="sr-only">网址</label>
          <input type="url" id="bm-form-url" placeholder="网址，如 https://example.com" />
          <select id="bm-form-cat"></select>
          <div class="bm-form-actions">
            <button type="button" class="btn" id="bm-form-cancel">取消</button>
            <button type="button" class="btn primary" id="bm-form-save">保存</button>
          </div>
        </div>

        <div class="bm-form" id="bm-batch-form" hidden data-squircle data-squircle-radius="16">
          <textarea id="bm-batch-text" rows="4" placeholder="每行：网址  标题（可选）  分组（可选）&#10;https://github.com  GitHub  Dev&#10;https://news.ycombinator.com  Hacker News"></textarea>
          <select id="bm-batch-cat"></select>
          <div class="bm-form-actions">
            <button type="button" class="btn" id="bm-batch-cancel">取消</button>
            <button type="button" class="btn primary" id="bm-batch-save">批量导入</button>
          </div>
        </div>

        <div class="bm-move-form" id="bm-move-form" hidden data-squircle data-squircle-radius="16">
          <label>移入分组：</label>
          <select id="bm-move-cat"></select>
          <div class="bm-form-actions">
            <button type="button" class="btn" id="bm-move-cancel">取消</button>
            <button type="button" class="btn primary" id="bm-move-save">确认</button>
            <button type="button" class="btn" id="bm-export-html">导出为 HTML</button>
            <button type="button" class="btn" id="bm-move-import">从文件导入</button>
            <button type="button" class="btn danger" id="bm-move-delete" style="margin-left:auto">删除</button>
          </div>
        </div>

        <div class="bm-grid" id="bm-grid"></div>

        <!-- 导入预览弹窗 -->
        <div id="import-popover" class="bm-popover" role="dialog" aria-modal="true" aria-label="导入书签" hidden>
          <div class="bm-popover-backdrop" data-import-close></div>
          <div class="bm-popover-panel" data-squircle data-squircle-radius="16" style="max-width:500px">
            <h3 style="margin:0 0 12px;font-size:14px;font-weight:600">导入书签</h3>
            <div id="import-preview-info" style="margin-bottom:8px"></div>
            <div id="import-preview-list" style="max-height:200px;overflow-y:auto;margin-bottom:8px;font-size:12px"></div>
            <div class="bm-form-actions" style="justify-content:space-between">
              <div>
                <label style="font-size:12px"><input type="radio" name="import-mode" value="merge" checked /> 合并</label>
                <label style="font-size:12px;margin-left:8px"><input type="radio" name="import-mode" value="replace" /> 替换</label>
              </div>
              <div>
                <button type="button" class="btn" data-import-close>取消</button>
                <button type="button" class="btn primary" id="import-confirm-btn">确认导入</button>
              </div>
            </div>
          </div>
        </div>
      </section>
      <section class="subpanel" data-subpanel="categories" hidden>
        <div class="cat-toolbar">
          <button type="button" class="btn primary" id="cat-add">+ 新建分组</button>
          <span class="cat-hint">删除分组后，原归属书签将移出分类（仍保留在「全部」中）</span>
        </div>

        <div class="cat-form" id="cat-add-form" hidden data-squircle data-squircle-radius="16">
          <label for="cat-add-name" class="sr-only">分组名</label>
          <input type="text" id="cat-add-name" placeholder="分组名，如：工作" />
          <div class="bm-form-actions">
            <button type="button" class="btn" id="cat-add-cancel">取消</button>
            <button type="button" class="btn primary" id="cat-add-save">保存</button>
          </div>
        </div>

        <div class="cat-list" id="cat-list"></div>
      </section>

      <!-- ============== 搜索引擎 ============== -->
      <section class="subpanel" data-subpanel="search" hidden>
        <div class="search-cards" id="search-cards"></div>
        <div class="bm-form" id="search-custom-form" hidden data-squircle data-squircle-radius="16">
          <input type="text" id="search-custom-name" placeholder="引擎名称，如：My Search" />
          <input type="text" id="search-custom-url" placeholder="搜索 URL，用 {q} 代替关键词，如：https://example.com/search?q={q}" />
          <div class="bm-form-actions">
            <button type="button" class="btn" id="search-custom-cancel">取消</button>
            <button type="button" class="btn primary" id="search-custom-save">保存</button>
          </div>
        </div>
        <p class="shortcut-footnote">终端栏输入任意文本按回车，将使用所选搜索引擎搜索；命中已有书签则直接打开对应链接。</p>
      </section>

      <!-- ============== 工作流 ============== -->
      <section class="subpanel" data-subpanel="workflows" hidden>
        <p class="shortcut-footnote tips">选择一个或多个书签保存为工作流，在主页输入 <kbd>wf+名称</kbd> 或 <kbd>workflow+名称</kbd> 批量打开。</p>
        <div class="cat-toolbar">
          <button type="button" class="btn primary" id="wf-add">+ 新建工作流</button>
        </div>
        <div class="cat-list" id="wf-list"></div>

        <div id="wf-popover" class="bm-popover" role="dialog" aria-modal="true" aria-label="新建工作流" hidden>
          <div class="bm-popover-backdrop" data-wf-close></div>
          <div class="bm-popover-panel" data-squircle data-squircle-radius="16">
            <input type="text" id="wf-popover-name" placeholder="输出名称，如：AI" />
            <label class="wf-field-label">链接（一行一条）</label>
            <textarea id="wf-popover-urls" rows="3" placeholder="https://example.com"></textarea>
            <div class="wf-cat-filters" id="wf-cat-filters"></div>
            <div class="bm-grid" id="wf-popover-grid" style="max-height:200px;overflow-y:auto"></div>
            <div class="bm-form-actions" style="margin-top:8px">
              <button type="button" class="btn" data-wf-close>取消</button>
              <button type="button" class="btn primary" id="wf-popover-save">保存</button>
            </div>
          </div>
        </div>
      </section>

      <!-- ============== 同步 ============== -->
      <section class="subpanel sync-panel" data-subpanel="sync" hidden>
        <div class="sync-panel-layout">
          <!-- 左侧：状态信息 -->
          <div class="sync-status-grid">
            <div class="sync-status-card">
              <h4 class="sync-section-title">账号</h4>
              <div class="sync-account-info" id="sync-account-info">
                <div class="sync-account-placeholder">未登录</div>
              </div>
            </div>
            <div class="sync-status-card">
              <h4 class="sync-section-title">同步状态</h4>
              <div class="sync-state-info" id="sync-state-info">
                <div class="sync-state-row">
                  <span class="sync-state-label">状态</span>
                  <span id="sync-indicator-text" class="sync-state-value">就绪</span>
                </div>
                <div class="sync-state-row">
                  <span class="sync-state-label">最后同步</span>
                  <span id="sync-last-time" class="sync-state-value sync-muted">—</span>
                </div>
                <div class="sync-state-row">
                  <span class="sync-state-label">存储</span>
                  <span id="sync-storage-info" class="sync-state-value sync-muted">本地: — · 远程: —</span>
                </div>
              </div>
            </div>
          </div>

          <!-- 右侧：操作区 -->
          <div class="sync-actions">
            <div class="sync-action-group" id="sync-unauth-actions" hidden>
              <button type="button" class="btn primary sync-btn-wide" id="sync-login-btn">登录</button>
              <button type="button" class="btn sync-btn-wide" id="sync-signup-btn">注册</button>
            </div>
            <div class="sync-action-group" id="sync-auth-actions" hidden>
              <div class="sync-direction-row">
                <label for="sync-direction-select" class="sync-direction-label">同步方向</label>
                <select id="sync-direction-select" class="sync-direction-select">
                  <option value="merge">智能合并（推荐）</option>
                  <option value="upload">本地上传 → 云端</option>
                  <option value="download">云端下载 → 本地</option>
                </select>
              </div>
              <button type="button" class="btn primary sync-btn-wide" id="sync-force-btn">立即同步</button>
              <label class="sync-toggle">
                <input type="checkbox" id="sync-auto-toggle" checked />
                <span class="sync-toggle-slider"></span>
                <span class="sync-toggle-label">自动同步</span>
              </label>
              <button type="button" class="btn sync-btn-wide" id="sync-logout-btn">退出登录</button>
            </div>
            <div class="sync-action-group" id="sync-unconfigured" hidden>
              <p class="sync-muted">同步功能需配置 Supabase</p>
              <a href="https://github.com/iszhjane/start-page/blob/main/SUPABASE.md" target="_blank" rel="noopener" class="sync-doc-link">查看配置文档 →</a>
            </div>
          </div>
        </div>

        <!-- 登录/注册模态框 -->
        <div id="sync-auth-modal" class="sync-modal" role="dialog" aria-modal="true" aria-labelledby="sync-modal-title" hidden>
          <div class="sync-modal-backdrop" data-sync-modal-close></div>
          <div class="sync-modal-panel" data-squircle data-squircle-radius="16">
            <h3 id="sync-modal-title" class="sync-modal-title">登录</h3>
            <p class="sync-modal-desc" id="sync-modal-desc">登录后可跨设备同步书签和设置</p>
            <div class="sync-modal-tabs" role="tablist">
              <button type="button" role="tab" aria-selected="true" class="sync-modal-tab active" data-sync-tab="login">登录</button>
              <button type="button" role="tab" aria-selected="false" class="sync-modal-tab" data-sync-tab="signup">注册</button>
            </div>
            <div class="sync-modal-panels">
              <!-- 登录面板 -->
              <div class="sync-modal-panel-content" data-sync-panel="login" hidden>
                <div class="sync-field">
                  <label for="sync-modal-email" class="sr-only">邮箱</label>
                  <input type="email" id="sync-modal-email" placeholder="邮箱" class="sync-input" autocomplete="email" />
                </div>
                <div class="sync-field">
                  <label for="sync-modal-password" class="sr-only">密码</label>
                  <input type="password" id="sync-modal-password" placeholder="密码" class="sync-input" autocomplete="current-password" />
                </div>
                <button type="button" class="btn sync-link-btn" id="sync-forgot-password">忘记密码？</button>
                <p id="sync-modal-error" class="sync-error" hidden></p>
                <div class="sync-modal-actions">
                  <button type="button" class="btn primary sync-btn-wide" id="sync-modal-login-btn">登录</button>
                </div>
              </div>
              <!-- 注册面板 -->
              <div class="sync-modal-panel-content" data-sync-panel="signup" hidden>
                <div class="sync-field">
                  <label for="sync-modal-signup-email" class="sr-only">邮箱</label>
                  <input type="email" id="sync-modal-signup-email" placeholder="邮箱" class="sync-input" autocomplete="email" />
                </div>
                <div class="sync-field">
                  <label for="sync-modal-signup-password" class="sr-only">密码</label>
                  <input type="password" id="sync-modal-signup-password" placeholder="密码（至少 6 位）" class="sync-input" autocomplete="new-password" />
                </div>
                <p id="sync-modal-signup-error" class="sync-error" hidden></p>
                <div class="sync-modal-actions">
                  <button type="button" class="btn primary sync-btn-wide" id="sync-modal-signup-btn">注册</button>
                </div>
              </div>
            </div>
            <div class="sync-modal-footer">
              <button type="button" class="btn sync-link-btn" data-sync-modal-close>取消</button>
            </div>
          </div>
        </div>

        <!-- 密码重置模态框 -->
        <div id="sync-reset-modal" class="sync-modal" role="dialog" aria-modal="true" aria-labelledby="sync-reset-title" hidden>
          <div class="sync-modal-backdrop" data-sync-reset-close></div>
          <div class="sync-modal-panel" data-squircle data-squircle-radius="16">
            <h3 id="sync-reset-title" class="sync-modal-title">重置密码</h3>
            <p class="sync-modal-desc">输入邮箱，我们将发送重置链接到你的邮箱</p>
            <div class="sync-field">
              <label for="sync-reset-email" class="sr-only">邮箱</label>
              <input type="email" id="sync-reset-email" placeholder="邮箱" class="sync-input" autocomplete="email" />
            </div>
            <p id="sync-reset-error" class="sync-error" hidden></p>
            <p id="sync-reset-success" class="sync-success" hidden></p>
            <div class="sync-modal-actions">
              <button type="button" class="btn primary sync-btn-wide" id="sync-reset-send-btn">发送重置邮件</button>
            </div>
            <div class="sync-modal-footer">
              <button type="button" class="btn sync-link-btn" data-sync-reset-close>取消</button>
            </div>
          </div>
        </div>
      </section>

      <!-- ============== 快捷键 ============== -->
      <section class="subpanel" data-subpanel="shortcuts" hidden>
        <div class="shortcut-table" data-squircle data-squircle-radius="16">
          <div class="shortcut-row">
            <div class="shortcut-label">聚焦输入框</div>
            <span class="shortcut-keys"><kbd class="shortcut-key">/</kbd></span>
          </div>
          <div class="shortcut-row">
            <div class="shortcut-label">下一分组</div>
            <span class="shortcut-keys"><kbd class="shortcut-key">Tab</kbd></span>
          </div>
          <div class="shortcut-row">
            <div class="shortcut-label">上一分组</div>
            <span class="shortcut-keys"><kbd class="shortcut-key">Shift</kbd><span class="shortcut-plus">+</span><kbd class="shortcut-key">Tab</kbd></span>
          </div>
          <div class="shortcut-row">
            <div class="shortcut-label">清空输入框</div>
            <span class="shortcut-keys"><kbd class="shortcut-key">Esc</kbd></span>
          </div>
          <div class="shortcut-row">
            <div class="shortcut-label">执行命令 / 打开命中</div>
            <span class="shortcut-keys"><kbd class="shortcut-key">Enter</kbd></span>
          </div>
          <div class="shortcut-row">
            <div class="shortcut-label">上一条历史命令</div>
            <span class="shortcut-keys"><kbd class="shortcut-key">↑</kbd></span>
          </div>
          <div class="shortcut-row">
            <div class="shortcut-label">下一条历史命令</div>
            <span class="shortcut-keys"><kbd class="shortcut-key">↓</kbd></span>
          </div>
          <div class="shortcut-row">
            <div class="shortcut-label">打开管理面板</div>
            <span class="shortcut-hint" style="margin-left:auto">点击右上角齿轮</span>
          </div>
        </div>
        <p class="shortcut-footnote">快捷键暂不支持自定义。</p>
      </section>

    </div>
  </div>
  <div id="mm-confirm" class="bm-popover" role="dialog" aria-modal="true" aria-label="确认操作" hidden>
    <div class="bm-popover-backdrop" data-mm-confirm-close></div>
    <div class="bm-popover-panel" data-squircle data-squircle-radius="16">
      <h3 id="mm-confirm-title">确认</h3>
      <p id="mm-confirm-text">确定执行此操作？</p>
      <div class="bm-popover-actions">
        <button type="button" class="btn" data-mm-confirm-close>取消</button>
        <button type="button" class="btn danger" id="mm-confirm-ok">确认</button>
      </div>
    </div>
  </div>
</div>

<style is:global>
  #manage-modal {
    position: fixed;
    inset: 0;
    z-index: 200;
    display: grid;
    place-items: center;
    padding: 2rem 1rem;
  }

  #manage-modal[hidden] {
    display: none;
  }

  .modal-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.4);
    backdrop-filter: blur(2px);
    -webkit-backdrop-filter: blur(2px);
  }

  .panel {
    position: relative;
    width: 100%;
    max-width: 920px;
    max-height: 85vh;
    background: var(--surface);
    border: 1px solid var(--border);
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.25);
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .panel-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 18px 24px 14px;
    flex-shrink: 0;
  }

  .panel-header h2 {
    font-size: 16px;
    font-weight: 600;
    color: var(--text);
  }

  .panel-header .icon-btn {
    width: 30px;
    height: 30px;
    border-radius: 50%;
    border: 1px solid var(--border);
    background: var(--surface-translucent);
    color: var(--text);
    cursor: pointer;
    display: grid;
    place-items: center;
  }
  .panel-header .icon-btn svg {
    width: 14px;
    height: 14px;
  }
  .panel-header .icon-btn:hover {
    background: var(--hover);
  }

  .subtabs {
    display: flex;
    gap: 6px;
    padding: 12px 24px 4px;
    flex-shrink: 0;
    flex-wrap: wrap;
  }

  .subtab {
    background: transparent;
    border: 1px solid transparent;
    padding: 6px 14px;
    font-size: 13px;
    font-weight: 500;
    color: var(--muted);
    cursor: pointer;
    transition: all var(--transition);
  }

  .subtab:hover {
    color: var(--text);
    background: var(--hover);
  }

  .subtab.active {
    background: var(--accent);
    color: white;
  }

  .panel-body {
    flex: 1;
    overflow-y: auto;
    padding: 20px 24px 24px;
  }

  .subpanel[hidden] {
    display: none;
  }

  /* ============== 主题 panel ============== */
  .theme-cards {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
  }

  .theme-card {
    cursor: pointer;
    border: 1px solid var(--border);
    padding: 16px;
    background: var(--surface-translucent);
    transition: all var(--transition);
    position: relative;
  }

  .theme-card:hover {
    transform: translateY(-2px);
  }

  .theme-card.active {
    border-color: var(--accent);
    box-shadow: 0 0 0 2px color-mix(in srgb, var(--accent) 30%, transparent);
  }

  .theme-card.active::after {
    content: "✓";
    position: absolute;
    top: 8px;
    right: 8px;
    width: 20px;
    height: 20px;
    background: var(--accent);
    color: white;
    border-radius: 50%;
    display: grid;
    place-items: center;
    font-size: 12px;
  }

  .theme-card-preview {
    height: 70px;
    border: 1px solid var(--border);
    margin-bottom: 12px;
    display: grid;
    place-items: center;
    font-size: 12px;
    overflow: hidden;
    position: relative;
  }

  .theme-card[data-theme="default"] .theme-card-preview {
    background: linear-gradient(135deg, #e9ecef, #dee2e6);
