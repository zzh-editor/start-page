---
// 客户端渲染：书签数据来自 store（localStorage）
// 渲染策略：1 张大卡片 = 20 个 li（4 列网格）
// tab 切换：命中优先 + 按 store.bookmarkSort 排序；未命中项轻度弱化
// 超过 20 个时启用横向滑动分页（每页 1 张大卡片 = 20 个）
---

<div id="bookmark-host"></div>

<style is:global>
  .bookmark-pages {
    position: relative;
    width: 100%;
  }

  .bookmark-pages-track {
    display: flex;
    gap: 16px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    -ms-overflow-style: none;
    width: 100%;
  }

  .bookmark-pages-track::-webkit-scrollbar {
    display: none;
  }

  .bookmark-page {
    flex: 0 0 100%;
    min-width: 0;
    scroll-snap-align: start;
  }

  .bookmark-list {
    background: var(--surface-translucent);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow);
    padding: 12px;
    width: 100%;
    min-width: 0;
  }

  .bookmark-list ul {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 6px;
  }

  .bookmark-list li {
    display: flex;
    align-items: center;
    gap: 8px;
    transition:
      opacity 0.25s ease,
      filter 0.25s ease;
    -webkit-touch-callout: none;
  }

  .bookmark-list li a {
    flex: 1;
    min-width: 0;
  }

  .bookmark-list li a {
    color: var(--text);
    text-decoration: none;
    display: flex;
    align-items: center;
    padding: 14px 16px;
    border-radius: var(--radius);
    background: transparent;
    font-size: 16px;
    font-weight: 500;
    transition:
      background var(--transition),
      transform var(--transition);
    position: relative;
  }

  .bookmark-list li a span {
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .bookmark-list li.bookmark-nomatch a {
    opacity: 0.45;
    filter: grayscale(50%);
  }

  .bookmark-list li a:hover {
    background: var(--hover);
    transform: translateX(2px);
    opacity: 1 !important;
    filter: none !important;
  }

  .bookmark-list li.bookmark-placeholder {
    pointer-events: none;
  }
  .bookmark-list li.bookmark-placeholder a {
    visibility: hidden;
  }

  .empty-hint {
    color: var(--muted);
    text-align: center;
    padding: 3rem 1rem;
    font-size: 14px;
  }

  .empty-hint kbd {
    display: inline-block;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 1px 6px;
    font-family: var(--mono);
    font-size: 12px;
    margin: 0 2px;
  }

  .pager-capsule {
    position: absolute;
    bottom: 16px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 6px 12px;
    background: color-mix(in srgb, var(--text) 20%, transparent);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border-radius: 100px;
    z-index: 10;
    pointer-events: auto;
  }

  .pager-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--border);
    border: none;
    padding: 0;
    cursor: pointer;
    transition: all 0.25s ease;
    flex-shrink: 0;
  }

  .pager-dot.active {
    background: var(--accent);
    width: 16px;
    border-radius: 4px;
  }

  .pager-dot:hover {
    background: color-mix(in srgb, var(--accent) 60%, transparent);
    transform: scale(1.3);
  }

  @media (max-width: 900px) {
    .bookmark-list ul {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 480px) {
    .bookmark-list ul {
      grid-template-columns: 1fr;
    }
    .bookmark-list li a {
      padding: 12px 14px;
      font-size: 15px;
    }
  }
</style>

<script>
  import {
    getState,
    subscribe,
    type Store,
    type Bookmark,
  } from "../lib/store";
  import { escapeHtml, escapeAttr } from "../lib/helpers";

  const PAGE_SIZE = 20;
  const host = document.getElementById("bookmark-host")!;
  let activeCategory: string = "all";
  let dataVersion = "";
  let currentPage = 0;
  let totalPages = 0;

  function getDataVersion(state: Store): string {
    const { bookmarks, bookmarkSort } = state;
    const bmKey = bookmarks.map((b) => `${b.id}:${b.categoryId}:${b.title}`).join(",");
    return `${bmKey}|${bookmarkSort}`;
  }

  window.addEventListener("tabs:change", (e) => {
    const newCat = (e as CustomEvent<string>).detail || "all";
    if (newCat === activeCategory) return;
    activeCategory = newCat;
  requestAnimationFrame(() => render(getState()));
  });

  window.addEventListener("shortcut:tab", (e) => {
    const direction = ((e as CustomEvent<{ direction: number }>).detail?.direction) ?? 1;
    const tabs = Array.from(
      document.querySelectorAll<HTMLButtonElement>("#tabs .tab"),
    );
    if (tabs.length === 0) return;
    const idx = tabs.findIndex((b) => b.classList.contains("active"));
    const current = idx === -1 ? 0 : idx;
    const next = (current + direction + tabs.length) % tabs.length;
    const nextTab = tabs[next];
    if (nextTab) nextTab.click();
  });

  subscribe(() => {
    const state = getState();
    const dv = getDataVersion(state);
    if (dv === dataVersion) return;
    dataVersion = dv;
    render(state);
  });
  render(getState());

  function render(state: Store): void {
    const { bookmarks } = state;

    if (bookmarks.length === 0) {
      host.innerHTML = `<div class="empty-hint">还没有书签。点击右上角 <strong>⚙</strong> 添加，或按 <kbd>/</kbd> 唤出管理面板。</div>`;
      totalPages = 0;
      return;
    }

    if (activeCategory !== "all" && !bookmarks.some((b) => b.categoryId === activeCategory)) {
      host.innerHTML = `<div class="empty-hint">该分类下还没有书签。</div>`;
      totalPages = 0;
      return;
    }

    currentPage = 0;
    const sorted = sortBookmarks(bookmarks, activeCategory, state.bookmarkSort);
    totalPages = Math.ceil(sorted.length / PAGE_SIZE);
    const pages: Bookmark[][] = Array.from({ length: totalPages }, (_, i) =>
      sorted.slice(i * PAGE_SIZE, (i + 1) * PAGE_SIZE),
    );

    const pagesHtml = pages
      .map((items) => {
        const padded: (Bookmark | null)[] = [...items];
        while (padded.length < PAGE_SIZE) padded.push(null);
        return `
        <div class="bookmark-page">
          <div class="bookmark-list" data-squircle data-squircle-radius="16">
            <ul>${padded.map((b) => b ? renderItem(b) : renderPlaceholder()).join("")}</ul>
          </div>
        </div>`;
      })
      .join("");

    const dotsHtml = totalPages > 1
      ? `<div class="pager-capsule">${Array.from({ length: totalPages }, (_, i) =>
          `<button type="button" class="pager-dot${i === 0 ? " active" : ""}" data-page="${i}" aria-label="第 ${i + 1} 页"></button>`
        ).join("")}</div>`
      : "";

    host.innerHTML = `<div class="bookmark-pages">${dotsHtml}<div class="bookmark-pages-track">${pagesHtml}</div></div>`;
    applyHighlight(activeCategory);

    if (totalPages > 1) {
      host.querySelectorAll<HTMLButtonElement>(".pager-dot").forEach((btn) => {
        btn.addEventListener("click", () => scrollToPage(Number(btn.dataset.page)));
      });
    }

    bindTrackScroll();
  }

  function sortBookmarks(items: Bookmark[], active: string, mode: Store["bookmarkSort"]): Bookmark[] {
    const sortAlpha = (a: Bookmark, b: Bookmark) => a.title.localeCompare(b.title);
    const sortAdded = (a: Bookmark, b: Bookmark) => b.createdAt - a.createdAt;

    const applyMode = (arr: Bookmark[]) => {
      if (mode === "added") return [...arr].sort(sortAdded);
      return [...arr].sort(sortAlpha);
    };

    if (active === "all") return applyMode(items);
    const matched = applyMode(items.filter((b) => b.categoryId === active));
    const unmatched = applyMode(items.filter((b) => b.categoryId !== active));
    return [...matched, ...unmatched];
  }

  function renderItem(b: Bookmark): string {
    return `
      <li data-id="${b.id}" data-category="${b.categoryId}">
        <a href="${escapeAttr(b.href)}" title="${escapeAttr(b.href)}" data-squircle data-squircle-radius="10">
          <span>${escapeHtml(b.title)}</span>
        </a>
      </li>
    `;
  }

  function renderPlaceholder(): string {
    return '<li class="bookmark-placeholder" aria-hidden="true"><a tabindex="-1">&nbsp;</a></li>';
  }

  function applyHighlight(active: string): void {
    document
      .querySelectorAll<HTMLLIElement>(".bookmark-list li")
      .forEach((li) => {
        if (li.classList.contains("bookmark-placeholder")) return;
        const isMatch = active === "all" || li.dataset.category === active;
        li.classList.toggle("bookmark-match", isMatch && active !== "all");
        li.classList.toggle("bookmark-nomatch", !isMatch);
      });
  }

  function onTrackScroll(this: HTMLElement): void {
    const pageWidth = this.clientWidth;
    if (pageWidth > 0) {
      const newPage = Math.round(this.scrollLeft / pageWidth);
      if (newPage !== currentPage) {
        currentPage = newPage;
        host.querySelectorAll<HTMLButtonElement>(".pager-dot").forEach((btn, i) => {
          btn.classList.toggle("active", i === currentPage);
        });
      }
    }
  }

  function bindTrackScroll(): void {
    const oldTrack = document.querySelector<HTMLElement>(".bookmark-pages-track");
    if (oldTrack) oldTrack.removeEventListener("scroll", onTrackScroll);
    const track = document.querySelector<HTMLElement>(".bookmark-pages-track");
    if (track) track.addEventListener("scroll", onTrackScroll, { passive: true });
  }

  function scrollToPage(index: number): void {
    const track = document.querySelector<HTMLElement>(".bookmark-pages-track");
    if (track) {
      currentPage = index;
      track.scrollTo({ left: index * track.clientWidth, behavior: "smooth" });
    }
  }
</script>
