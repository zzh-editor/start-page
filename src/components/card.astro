---
const { links } = (await Astro.glob("../content/bookmarks.md"))[0].frontmatter;

links.sort((a, b) => a.title.localeCompare(b.title));

---
<section class="bookmark-sections">
  <!-- Section 1 -->
  <md-outlined-card class="bookmark-section">
    <md-list>
      {links.slice(0, 5).map((link) => ( <!-- First 5 bookmarks -->
        <md-list-item headline={link.title} href={link.href}>
          <md-icon slot="start">
            <img src={link.src} alt={link.alt} />
          </md-icon>
        </md-list-item>
      ))}
    </md-list>
  </md-outlined-card>

  <!-- Section 2 -->
  <md-outlined-card class="bookmark-section">
    <md-list>
      {links.slice(5, 10).map((link) => ( <!-- Next 5 bookmarks -->
        <md-list-item headline={link.title} href={link.href}>
          <md-icon slot="start">
            <img src={link.src} alt={link.alt} />
          </md-icon>
        </md-list-item>
      ))}
    </md-list>
  </md-outlined-card>

  <!-- Section 3 -->
  <md-outlined-card class="bookmark-section">
    <md-list>
      {links.slice(10, 15).map((link) => ( <!-- Next 5 bookmarks -->
        <md-list-item headline={link.title} href={link.href}>
          <md-icon slot="start">
            <img src={link.src} alt={link.alt} />
          </md-icon>
        </md-list-item>
      ))}
    </md-list>
  </md-outlined-card>

  <!-- Section 4 -->
  <md-outlined-card class="bookmark-section">
    <md-list>
      {links.slice(15, 20).map((link) => ( <!-- Next 5 bookmarks -->
        <md-list-item headline={link.title} href={link.href}>
          <md-icon slot="start">
            <img src={link.src} alt={link.alt} />
          </md-icon>
        </md-list-item>
      ))}
    </md-list>
  </md-outlined-card>
</section>

<style>
  .bookmark-sections {
    display: flex;
    flex-direction: row;
    flex-wrap: wrap;
    gap: 20px;
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
  }

  .bookmark-section {
    /* background: rgba(255, 255, 255, 0.1); backdrop-filter: blur(10px); */ /* Removed for MWC styling */
    /* border-radius: 12px; */ /* MWC card will have its own radius */
    /* box-shadow: 0 4px 10px rgba(0, 0, 0, 0.2); */ /* MWC card will have its own shadow */
    /* padding: 10px; */ /* MWC card has its own padding */
    flex: 1 1 calc(20% - 20px); /* Keep flex sizing for now */
    /* border: 1px solid black */ /* MWC card has its own border */
  }

  /* Ensure images inside md-icon are reasonably sized if they are too big by default */
  md-icon img {
    max-width: 24px;
    max-height: 24px;
  }

  @media (max-width: 600px) {
    .bookmark-sections {
      flex-direction: column;
      gap: 10px;
    }
  }
</style>